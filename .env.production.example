# Tên miền đã trỏ DNS A về IP VPS. Caddy sẽ tự cấp/gia hạn HTTPS.
DOMAIN=dinhduong.example.vn

# PostgreSQL/Supabase: tuyệt đối không đưa chuỗi thật vào Git hay gửi qua chat.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# AI là tùy chọn. Bỏ trống nếu chưa bật.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Không bật trên website chính thức. Nếu cần kiểm tra nội bộ, mật khẩu tối thiểu 12 ký tự.
ENABLE_PREVIEW_ADMIN=false
ADMIN_PREVIEW_PASSWORD=
