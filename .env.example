# Chỉ dùng ở server; không đưa các giá trị thật vào Git.
DATABASE_URL=

# AI là tùy chọn, chỉ dùng cho người dùng đã đăng nhập.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Bắt buộc khi quản trị viên lưu Gemini trong Admin. Tạo chuỗi ngẫu nhiên dài 32+ ký tự; không đưa vào Git/chat.
APP_SECRET=

# Chỉ bật khi kiểm tra nội bộ. Không bật trên website chính thức.
ENABLE_PREVIEW_ADMIN=false
ADMIN_PREVIEW_PASSWORD=
